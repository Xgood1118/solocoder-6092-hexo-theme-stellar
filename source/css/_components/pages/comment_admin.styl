.comment-admin-panel
  padding: 20px
  max-width: 1200px
  margin: 0 auto

  .admin-header
    margin-bottom: 24px

    .admin-title
      font-size: 24px
      font-weight: 600
      color: var(--text-p1)
      margin: 0 0 16px 0

  .admin-stats
    display: flex
    gap: 16px
    flex-wrap: wrap

    .stat-item
      flex: 1
      min-width: 120px
      background: var(--card)
      border-radius: $border-card
      padding: 16px 20px
      display: flex
      flex-direction: column
      gap: 8px
      border: 1px solid var(--border)

      .stat-label
        font-size: $fs-13
        color: var(--text-p2)

      .stat-value
        font-size: 28px
        font-weight: 600
        color: var(--text-p1)

      &.pending .stat-value
        color: #ff9800

      &.approved .stat-value
        color: #4caf50

      &.total .stat-value
        color: var(--theme)

  .admin-toolbar
    display: flex
    align-items: center
    gap: 16px
    margin-bottom: 20px
    padding: 16px
    background: var(--card)
    border-radius: $border-card
    border: 1px solid var(--border)
    flex-wrap: wrap

    .filter-group
      display: flex
      align-items: center
      gap: 8px

      label
        font-size: $fs-13
        color: var(--text-p2)
        white-space: nowrap

    .form-select
      padding: 6px 10px
      border: 1px solid var(--border)
      border-radius: 6px
      background: var(--bg)
      color: var(--text-p1)
      font-size: $fs-13
      cursor: pointer
      outline: none
      transition: border-color 0.2s ease

      &:hover
      &:focus
        border-color: var(--theme)

    .batch-actions
      margin-left: auto
      display: flex
      align-items: center
      gap: 10px

      .select-all
        display: flex
        align-items: center
        gap: 6px
        font-size: $fs-13
        color: var(--text-p2)
        cursor: pointer

      input[type="checkbox"]
        cursor: pointer

  .btn
    padding: 8px 16px
    border: none
    border-radius: 6px
    font-size: $fs-13
    cursor: pointer
    transition: all 0.2s ease
    font-weight: 500

    &:disabled
      opacity: 0.5
      cursor: not-allowed

    &.btn-approve
      background: #4caf50
      color: white

      &:hover:not(:disabled)
        background: #43a047

    &.btn-delete
      background: #f44336
      color: white

      &:hover:not(:disabled)
        background: #e53935

    &.btn-refresh
      background: var(--theme)
      color: white

      &:hover:not(:disabled)
        opacity: 0.9

  .comment-list-container
    background: var(--card)
    border-radius: $border-card
    border: 1px solid var(--border)
    min-height: 300px
    position: relative

    .loading-state
      display: flex
      flex-direction: column
      align-items: center
      justify-content: center
      padding: 60px 20px
      gap: 16px

      img
        width: 32px
        height: 32px

      p
        color: var(--text-p2)
        font-size: $fs-14

    .empty-state
      display: flex
      align-items: center
      justify-content: center
      padding: 60px 20px

      p
        color: var(--text-p3)
        font-size: $fs-14

    .comment-list
      padding: 0

  .comment-item
    display: flex
    gap: 12px
    padding: 16px
    border-bottom: 1px solid var(--border)
    transition: background 0.2s ease
    cursor: pointer
    position: relative

    &:last-child
      border-bottom: none

    &:hover
      background: var(--bg-a50)

    &.unread
      background: var(--theme-a5)

      &:hover
        background: var(--theme-a10)

    &.read
      opacity: 0.9

  .comment-checkbox
    display: flex
    align-items: flex-start
    padding-top: 4px

    input[type="checkbox"]
      width: 16px
      height: 16px
      cursor: pointer

  .comment-avatar
    flex-shrink: 0
    width: 40px
    height: 40px
    border-radius: 50%
    overflow: hidden
    background: var(--block)

    img
      width: 100%
      height: 100%
      object-fit: cover

    .avatar-placeholder
      width: 100%
      height: 100%
      display: flex
      align-items: center
      justify-content: center
      background: var(--theme)
      color: white
      font-weight: 600
      font-size: 16px

  .comment-content
    flex: 1
    min-width: 0

    .comment-header
      display: flex
      align-items: center
      gap: 8px
      margin-bottom: 6px
      flex-wrap: wrap

      .comment-author
        font-weight: 600
        color: var(--text-p1)
        font-size: $fs-14

      .comment-source
        font-size: $fs-11
        color: white
        padding: 2px 6px
        border-radius: 4px
        font-weight: 500

      .comment-date
        font-size: $fs-12
        color: var(--text-p3)

      .comment-status
        font-size: $fs-11
        padding: 2px 6px
        border-radius: 4px
        font-weight: 500

        &.pending-badge
          background: #fff3e0
          color: #ff9800

        &.approved-badge
          background: #e8f5e9
          color: #4caf50

    .comment-body
      font-size: $fs-14
      color: var(--text-p1)
      line-height: 1.6
      margin-bottom: 8px
      word-break: break-word

    .comment-page
      font-size: $fs-12
      color: var(--text-p3)

      .page-label
        margin-right: 4px

      a
        color: var(--theme)
        text-decoration: none

        &:hover
          text-decoration: underline

  .comment-actions
    display: flex
    flex-direction: column
    gap: 6px
    flex-shrink: 0

    .action-btn
      width: 28px
      height: 28px
      border: none
      border-radius: 6px
      cursor: pointer
      font-size: 14px
      display: flex
      align-items: center
      justify-content: center
      transition: all 0.2s ease
      background: var(--bg-a50)

      &.approve-btn
        color: #4caf50

        &:hover
          background: #e8f5e9
          transform: scale(1.1)

      &.undo-btn
        color: #ff9800

        &:hover
          background: #fff3e0
          transform: scale(1.1)

      &.delete-btn
        color: #f44336

        &:hover
          background: #ffebee
          transform: scale(1.1)

  .pagination-bar
    display: flex
    align-items: center
    justify-content: center
    gap: 16px
    padding: 20px
    border-top: 1px solid var(--border)

    .btn-page
      padding: 6px 14px
      border: 1px solid var(--border)
      border-radius: 6px
      background: var(--bg)
      color: var(--text-p1)
      cursor: pointer
      font-size: $fs-13
      transition: all 0.2s ease

      &:hover:not(:disabled)
        border-color: var(--theme)
        color: var(--theme)

      &:disabled
        opacity: 0.5
        cursor: not-allowed

    .page-info
      font-size: $fs-13
      color: var(--text-p2)

@media screen and (max-width: $device-mobile)
  .comment-admin-panel
    padding: 12px

    .admin-toolbar
      .batch-actions
        margin-left: 0
        width: 100%
        justify-content: flex-start

    .comment-item
      flex-wrap: wrap

    .comment-actions
      flex-direction: row
      width: 100%
      justify-content: flex-end
      padding-left: 52px
